# Deployer wallet (owner). Use a throwaway key funded with Sepolia ETH only.
PRIVATE_KEY=0x...

# Off-chain attester address (the public address of ATTESTER_PRIVATE_KEY in backend/.env).
ATTESTER_ADDRESS=0x...

# Token metadata base URI (must end with /). e.g. your backend /api/token/
BASE_URI=https://your-backend.example.com/api/token/

# Verification + RPC
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
ETHERSCAN_API_KEY=your_etherscan_key
