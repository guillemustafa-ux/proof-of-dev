# Required: Etherscan v2 API key (single key works across mainnet + sepolia).
ETHERSCAN_API_KEY=your_etherscan_key

# Optional: mainnet RPC for ENS resolution (Alchemy/Infura/public).
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key

# Attester key — signs EIP-712 mint attestations (keep server-side only, fund minimally).
ATTESTER_PRIVATE_KEY=0x...

# Deployed ProofOfDev contract address (for signing mint attestations).
PROOF_OF_DEV_ADDRESS=0x...

PORT=8000
